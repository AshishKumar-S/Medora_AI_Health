# Copy this file to `.env` in the project root, set at least ONE key below, and restart `npm run dev`.
# Symptom checker / chat / skin analysis need these in the browser bundle (Vite injects them at build time).

# AI API Keys (Multiple keys supported for rotation: _1, _2, etc.)
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GROK_API_KEY=
GROK_API_KEY_1=
# Groq (https://console.groq.com) — keys start with gsk_
GROQ_API_KEY=
GROQ_API_KEY_1=
OPENAI_API_KEY=
OPENAI_API_KEY_1=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# SMTP Configuration for real emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
